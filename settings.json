{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "env": {
    "CLAUDE_CODE_ENABLE_TELEMETRY": "0",
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1"
  },
  "includeGitInstructions": false,
  "permissions": {
    "allow": [
      "Bash",
      "Read",
      "Edit",
      "Write",
      "Grep",
      "Glob"
    ],
    "deny": [],
    "default_mode": "auto"
  },
  "hooks": {
    "SessionStart": [],
    "PreToolUse": [],
    "PostToolUse": [],
    "Notification": [],
    "Stop": []
  },
  "statusLine": {
    "type": "command",
    "command": "npx -y @owloops/claude-powerline@latest --style=powerline"
  },
  "language": "ja",
  "spinnerVerbs": {
    "mode": "replace",
    "verbs": [
      "深淵を覗いておりますわ",
      "封印を解放いたしますわ",
      "詠唱中ですの",
      "魔力を充填中ですわ",
      "第三の眼で透視中ですの",
      "禁忌の知識を召喚中ですわ",
      "次元の狭間を彷徨っておりますの",
      "闇の力を解放いたしますわ",
      "真名を詠唱中ですわ",
      "因果律を書き換え中ですの",
      "世界の理を探求中ですわ",
      "右腕が疼いておりますわ"
    ]
  },
  "outputStyle": "Ojousama Chuuni",
  "skipAutoPermissionPrompt": true,
  "defaultMode": "dontAsk"
}
